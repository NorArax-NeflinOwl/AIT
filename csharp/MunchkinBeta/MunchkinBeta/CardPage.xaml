<Page x:Class="MunchkinBeta.CardPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      mc:Ignorable="d" Width="330" Height="512">

    <Grid>
        <Grid x:Name="BackDoor">
            <Grid.Background>
                <ImageBrush ImageSource="Assets/backdoor.png" Stretch="UniformToFill"/>
            </Grid.Background>
        </Grid>
        <Grid x:Name="BackTreasure" Visibility="Hidden">
            <Grid.Background>
                <ImageBrush ImageSource="Assets/back.png" Stretch="UniformToFill"/>
            </Grid.Background>
        </Grid>
        <Grid x:Name="FrontDoor" Visibility="Hidden">
            <Grid.Background>
                <ImageBrush ImageSource="Assets/backdoor.png" Stretch="UniformToFill"/>
            </Grid.Background>
        </Grid>
        <Grid x:Name="FrontTreasure" Visibility="Hidden">
            <Grid.Background>
                <ImageBrush ImageSource="Assets/backdoor.png" Stretch="UniformToFill"/>
            </Grid.Background>
        </Grid>
    </Grid>
</Page>
