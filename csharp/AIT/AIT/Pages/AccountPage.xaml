<Page
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      x:Class="AIT.Pages.AccountPage"
      mc:Ignorable="d" Background="LightGray"
      d:DesignHeight="450" d:DesignWidth="800"
      Title="AccountPage">

    <ScrollViewer Margin="10,0" HorizontalScrollBarVisibility="Auto">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="250"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Grid Grid.Column="0">
                <Label Content="Personal details:" Foreground="#032b86" FontSize="22"/>
                <Frame x:Name="aitAccountFrame"/>
            </Grid>
            <Button x:Name="aitSaveBtn" Content="Save" Grid.Column="1" 
                    Background="#032b86" HorizontalAlignment="Right" 
                    Margin="10" VerticalAlignment="Bottom" Width="100"/>
            <Button x:Name="aitDeleteAccountBtn" Content="Delete user" Grid.Column="1" 
                    Background="#FF880E0E" HorizontalAlignment="Right" 
                    Margin="0,0,121.2,9.6" VerticalAlignment="Bottom" Width="110"/>
        </Grid>
    </ScrollViewer>
</Page>
