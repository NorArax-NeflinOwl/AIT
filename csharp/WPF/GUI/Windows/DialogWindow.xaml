<Window x:Class="WPF.GUI.Windows.DialogWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" 
        
        DataContext="{Binding RelativeSource={RelativeSource Self}}"
        Title="{Binding Properties.Title}" 
        Height="{Binding Properties.Heigth}" 
        Width="{Binding Properties.Width}" 
        ResizeMode="{Binding Properties.ResizeMode}"
        WindowStyle="{Binding Properties.WindowStyle}"
        WindowStartupLocation="{Binding Properties.WindowStartupLocation}"
        Topmost="{Binding Properties.Topmost}" 
        ShowInTaskbar="False">
    
    <Grid Background="LightGray">
        <Grid>
            
        </Grid>
    </Grid>
</Window>
