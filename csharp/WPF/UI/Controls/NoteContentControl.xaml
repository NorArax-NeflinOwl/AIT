<UserControl x:Class="WPF.UI.Controls.NoteContentControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:WPF.UI.Controls"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid Background="LightGray">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="200"/>
            </Grid.ColumnDefinitions>
            <TextBlock x:Name="MessageTitle" Margin="10,10,0,10" Text="Message:" Grid.Column="0"/>
            <TextBlock x:Name="DateTitle" Margin="10,10,0,10" Text="Create Date:" Grid.Column="2"/>
            <TextBox x:Name="Date" IsEnabled="false" Margin="10" Text="Unknown" Grid.Column="3"/>
        </Grid>
        <TextBox x:Name="MessageContent" Grid.Row="1" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" FontSize="14"/>
    </Grid>
</UserControl>
