<?xml version='1.0' encoding='UTF-8'?>
<!DOCTYPE hibernate-configuration PUBLIC
        "-//Hibernate/Hibernate Configuration DTD 3.0//EN"
        "http://www.hibernate.org/dtd/hibernate-configuration-3.0.dtd">

<hibernate-configuration>
    <session-factory>
        <property name="hibernate.dialect">org.hibernate.dialect.MySQLDialect</property>

        <property name="hibernate.connection.driver_class">com.mysql.cj.jdbc.Driver</property>

        <property name="hibernate.connection.url">jdbc:mysql://localhost:3306/ait?serverTimezone=Europe/Warsaw</property>

        <property name="hibernate.hbm2ddl.auto">update</property>

        <property name="connection.pool_size">1</property>

        <property name="show_sql">true</property>

        <mapping class="com.hbm.models.entities.AitAccountEntity" />
        <mapping class="com.hbm.models.entities.AitUserDataEntity" />
        <mapping class="com.hbm.models.entities.AitSettingEntity" />
        <mapping class="com.hbm.models.entities.AitNoteEntity" />
        <mapping class="com.hbm.models.entities.AitUserHostEntity" />

        <!--<mapping resource="com.arno.entities/AitAccount.hbm.xml" />
        <mapping resource="com.arno.entities/AitUserData.hbm.xml" />-->
    </session-factory>
</hibernate-configuration>