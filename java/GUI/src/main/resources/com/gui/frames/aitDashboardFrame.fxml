<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Menu?>
<?import javafx.scene.control.MenuBar?>
<?import javafx.scene.control.MenuItem?>
<?import javafx.scene.layout.AnchorPane?>
<AnchorPane minHeight="700.0" minWidth="1000.0" prefHeight="700.0" prefWidth="1000.0"
            xmlns="http://javafx.com/javafx/8.0.172-ea" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.gui.frames.AitDashboardController">
    <MenuBar nodeOrientation="LEFT_TO_RIGHT" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
      <menus>
          <Menu fx:id="fileMenu" mnemonicParsing="false" text="File">
              <items>
               <MenuItem fx:id="closeAllItem" mnemonicParsing="false" text="Close All" />
               <MenuItem fx:id="settingsItem" mnemonicParsing="false" text="Settings" />
               <MenuItem fx:id="logoutItem" mnemonicParsing="false" text="Log Out" />
               <MenuItem fx:id="exitItem" mnemonicParsing="false" text="Exit" />
              </items>
          </Menu>
          <Menu fx:id="editMenu" mnemonicParsing="false" text="Edit">
              <items>
                  <MenuItem fx:id="undoItem" mnemonicParsing="false" text="Undo" />
                  <MenuItem fx:id="redoItem" mnemonicParsing="false" text="Redo" />
              </items>
          </Menu>
         <Menu fx:id="viewMenu" mnemonicParsing="false" text="View">
            <items>
               <MenuItem fx:id="dashboardItem" mnemonicParsing="false" text="Dashboard" />
               <MenuItem fx:id="createAccountItem" mnemonicParsing="false" text="Create account" />
            </items>
         </Menu>
          <Menu fx:id="helpMenu" mnemonicParsing="false" text="Help">
              <items>
                  <MenuItem fx:id="reqisterProductItem" mnemonicParsing="false" text="Register Procuct" />
                  <MenuItem fx:id="aboutItem" mnemonicParsing="false" text="About" />
              </items>
          </Menu>
      </menus>
    </MenuBar>
</AnchorPane>
