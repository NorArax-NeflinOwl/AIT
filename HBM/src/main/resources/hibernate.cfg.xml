<?xml version='1.0' encoding='UTF-8'?>
<!DOCTYPE hibernate-configuration PUBLIC
        "-//Hibernate/Hibernate Configuration DTD 3.0//EN"
        "http://www.hibernate.org/dtd/hibernate-configuration-3.0.dtd">

<hibernate-configuration>
    <session-factory>
        <property name="com.hbm.hibernate.current_session_context_class">org.hibernate.context.internal.ThreadLocalSessionContext</property>
        <property name="com.hbm.hibernate.dialect">org.hibernate.dialect.MySQLDialect</property>
        <property name="com.hbm.hibernate.connection.driver_class">com.mysql.cj.jdbc.Driver</property>
        <property name="com.hbm.hibernate.connection.url">jdbc:mysql://localhost:3306/ait?serverTimezone=Europe/Warsaw</property>
        <property name="com.hbm.hibernate.connection.username">root</property>
        <property name="com.hbm.hibernate.connection.password">#_@rnn0I</property>

        <property name="show_sql">true</property>
        <!--
        <mapping class="com.hbm.entities.AccountEntity" />
        <mapping class="com.hbm.entities.UserDataEntity" />
        <mapping resource="com.arno.entities/Account.hbm.xml" />
        <mapping resource="com.arno.entities/UserData.hbm.xml" />-->
    </session-factory>
</hibernate-configuration>