SELECT Count(*) OVER () AS PACKAGE_ROW,
                     (CASE
                          WHEN (v.ITEM_TYPE IN ('T',
                                                'E',
                                                'F',
                                                'P',
                                                'S')) THEN v.GP_OTST_STATUS
                          ELSE (CASE
                                    WHEN (v.ITEM = 'Order') THEN ''
                                    ELSE 'Pending for '
                                END) || v.ACTIVITY
                      END) AS ACTIVITY_STATUS,
                     ROUND(MONTHS_BETWEEN(SYSDATE, v.GP_PAT_DOB)/12, 0) AS GP_PAT_DOB_NUM,
                     NVL(
                           (SELECT GP_ORD_MONITORED
                            FROM GP_ORDER
                            WHERE GP_ORD_ORDNUM = v.ORIGINAL_LABNO), 'N') AS GP_ORD_MONITORED,
                     GCM_GET_MAX_TAT_IMAGE(v.ORIGINAL_LABNO, v.TST, GS_TST_TAT, GS_TST_TATHIGH, 0, 1440, 'A') AS IMAGE,
                     v.ORDNUM,
                     v.GP_ORD_EXTNUM,
                     v.GP_ORD_SECEXTNUM,
                     v.SIGNOUT,
                     v.GP_PAT_RECID,
                     v.GP_ORD_VISID,
                     v.GP_ORD_ORDNUM,
                     v.ANALYSIS_KEYPAD,
                     v.ORIGINAL_LABNO,
                     v.GP_ORD_RECID,
                     v.GP_ORD_GRP,
                     v.GP_ORD_PRIOR,
                     v.GP_ORD_REGDT,
                     v.TST,
                     v.GP_ORD_ISIFLOW,
                     v.ITEM,
                     v.GS_TST_CODE,
                     v.ALIASNUM,
                     v.ACTIVITY,
                     v.GP_PAT_LNAME,
                     v.FAMILY_NUM,
                     v.GP_PAT_HLA,
                     v.GP_PAT_FULLNAME,
                     v.GP_PAT_DOB,
                     v.GP_PAT_SEX,
                     v.GP_PAT_SUFFIX,
                     v.GP_PAT_TITLE,
                     v.GP_PAT_MRN,
                     v.UNIQUEID,
                     v.RELATED_UNIQUEID,
                     v.GP_REQI_REPNUM,
                     v.GP_PLR_OTHERS,
                     v.GP_PLR_OWNTP,
                     v.PANEL_TUBE_TASKLIST_NUMBER,
                     v.GP_SPE_GEST,
                     v.NUMSLIDE,
                     v.NUMPANSLIDE,
                     v.ASSIGN,
                     v.GP_ASH_ITEMTYPE,
                     v.ASHDATE,
                     v.ITEM_TYPE,
                     v.GP_ORD_PATHOLOGIST,
                     v.GS_TST_TAT,
                     v.GS_TST_TATHIGH,
                     v.SYSTEM_TYPE,
                     v.ORDER_DEPARTMENT,
                     v.PERF_DEPARTMENT,
                     v.ORD_DEP_CODE,
                     v.PRF_DEP_CODE,
                     v.ORDERED_TESTS,
                     v.NEW_PATIENT,
                     v.GP_TSTWKL_RECID,
                     v.ACTIVE_NOTE,
                     v.ORDER_SYSTEM_TYPE,
                     v.SITE,
                     v.ENTRY,
                     v.STATUS,
                     v.PREV_ITEM,
                     v.LOCK_TYPE,
                     v.GP_OTST_CODE,
                     v.GP_OTST_PRIORITY,
                     v.GP_OTST_REGDT,
                     v.GP_OTST_ISPRELREP,
                     v.KTYPE,
                     v.GP_ORD_ABN,
                     v.GP_ORD_GESTAGE,
                     REPLACE(REPLACE(REPLACE(v.IND_TST, '|', ','), '/,', '|'), '//', '/') AS IND_TST,
                     GP_ORD_LMOD,
                     REPLACE(REPLACE(REPLACE(v.SPEC_TYPES, '|', ','), '/,', '|'), '//', '/') AS SPEC_TYPES,
                     v.CLINIC_NAME,
                     v.MONITREASON,
                     v.INDICATIONNAMES,
                     v.USER_LASTACT,
                     v.ISTASKLISTS,
                     v.PARENT_ID,
                     v.UNIQUEID || '-' || v.ITEM_TYPE AS ROW_ID,
                     v.GC_CL_TIMEZONE,
                     v.GP_SPE_COLDT,
                     v.GP_REQI_RECID,
                     v.GP_OTST_RECID,
                     v.GP_REQI_DEPTYPE,
                     v.GP_REQI_TESTID,
                     v.GP_REQI_INTTYPE AS INT_TYPE,
                     v.GP_INT_ABN AS ABN,
                     v.GP_INT_DGNCAT,
                     v.TASKLIST_NUM AS TASKLIST_NUM,
                     v.SAMPLEID AS SAMPLEID,
                     v.TUBE_EXTNUM AS TUBE_EXTNUM,
                     v.PROBES,
                     v.FLWRUN_PATH,
                     v.TKL_POS,
                     v.GP_PLR_PRQACODE,
                     v.QUALITY_DESC,
                     v.PENDINGSTAINS
FROM
  (SELECT view_records.*, ROWNUM ROW_NUM,
                                 GP_PAT_RECID,
                                 Nvl2 (GP_PAT_FNAME, GP_PAT_LNAME || ', ' || GP_PAT_FNAME, GP_PAT_LNAME) AS GP_PAT_LNAME,
                                 GET_PATFAMNUMS(GP_PAT_RECID) AS FAMILY_NUM,
                                 GP_PAT_HLA,
                                 GP_PAT_DOB,
                                 GP_PAT_SEX,
                                 GP_PAT_SUFFIX,
                                 GP_PAT_TITLE,
                                 GP_PAT_MRN,
                                 (CASE
                                      WHEN ETYPE = 'INT_REQ' THEN Nvl2 (GP_PAT_FNAME, GP_PAT_LNAME || ', ' || GP_PAT_FNAME, GP_PAT_LNAME)
                                      ELSE ''
                                  END) AS GP_PAT_FULLNAME,

     (SELECT GS_CLIN_LNAME
      FROM v_gcm_cmn_clinic
      WHERE GS_CLIN_LCODE = GP_VIS_CLINIC) AS CLINIC_NAME,

     (SELECT GS_CLIN_TIMEZONE
      FROM v_gcm_cmn_clinic
      WHERE GS_CLIN_LCODE = GP_VIS_CLINIC) AS GC_CL_TIMEZONE,

     (SELECT GS_CLIN_MONITREASON
      FROM v_gcm_cmn_clinic,
           GP_VISIT
      WHERE GS_CLIN_LCODE = GP_VIS_CLINIC
        AND GP_VIS_RECID = GP_ORD_VISID) AS MONITREASON,

     (SELECT GS_PLC_CODE
      FROM GS_PLACE
      WHERE GS_PLC_RECID = ORD_DEP_RECID) AS ORD_DEP_CODE,

     (SELECT GS_DEP_CODE
      FROM GS_DEPARTMENT
      WHERE GS_DEP_RECID = PRF_DEP_RECID) AS PRF_DEP_CODE,

     (SELECT GS_PRI_NAME
      FROM GS_PRIORITY
      WHERE GS_PRI_CODE = ORD_PRIOR) AS GP_ORD_PRIOR,
                                 (CASE
                                      WHEN (ITEM_TYPE IN ('L',
                                                          'K')) THEN NULL
                                      WHEN (ITEM_TYPE IN ('R',
                                                          'S',
                                                          'F')
                                            OR (ITEM_TYPE = 'P'
                                                AND RELATED_UNIQUEID IS NULL)) THEN TST_ID
                                      ELSE
                                             (SELECT ROUND((SYSDATE - GP_ORD_REGDT) * 24 * 60, 0) AS TAT_VALUE
                                              FROM GP_OTEST,
                                                   GP_ORDER
                                              WHERE GP_ORD_ORDNUM = GP_OTST_ORDNUM
                                                AND GP_OTST_RECID = TST_ID )
                                  END) AS TST,
                                 (CASE
                                      WHEN ITEM_TYPE IN ('O',
                                                         'A',
                                                         'K',
                                                         'L') THEN NULL
                                      WHEN (SYSTEM_TYPE = 'P') THEN
                                             (SELECT COUNT(GP_P_SLD_RECID)
                                              FROM GP_DXP_SLIDE,
                                                   GP_OTEST o
                                              WHERE o.GP_OTST_ORDNUM = ORIGINAL_LABNO
                                                AND GP_P_SLD_PANELID = o.GP_OTST_RECID )
                                      ELSE NULL
                                  END) AS NUMPANSLIDE,
                                 (CASE
                                      WHEN ITEM_TYPE IN('Q',
                                                        'Y',
                                                        'F',
                                                        'T',
                                                        'P',
                                                        'S') THEN get_test_and_order_locks(NULL, NULL, NULL, GP_REQI_RECID, NULL)
                                      WHEN ITEM_TYPE IN('N',
                                                        'PA',
                                                        'I') THEN get_test_and_order_locks(NULL, NULL, NULL, NULL, ORIGINAL_LABNO)
                                      WHEN ITEM_TYPE IN('E',
                                                        'O',
                                                        'I') THEN get_test_and_order_locks(NULL, NULL, TST_ID, NULL, NULL)
                                      WHEN ITEM_TYPE IN('C',
                                                        'A') THEN get_test_and_order_locks(NULL, NULL, nvl(TST_ID, -1), NULL, ORIGINAL_LABNO)
                                      WHEN ITEM_TYPE = 'K' THEN DECODE(
                                                                         (SELECT GP_LCK_TYPE
                                                                          FROM GP_LOCK
                                                                          WHERE GP_LCK_OWNID = GP_ORD_RECID), 'G', 'G')
                                      ELSE NULL
                                  END) AS LOCK_TYPE,
                                 (CASE
                                      WHEN ITEM_TYPE IN('L',
                                                        'K') THEN NULL
                                      WHEN ITEM_TYPE IN('O',
                                                        'E') THEN gcm_get_tubeextnum_for_test(TST_ID)
                                      WHEN ITEM_TYPE IN('F',
                                                        'T',
                                                        'P',
                                                        'S') THEN gcm_get_tubeextnum_for_interp(GP_REQI_RECID)
                                      ELSE gcm_get_tubeextnum_for_order(ORDNUM)
                                  END) AS TUBE_EXTNUM,
                                 (CASE
                                      WHEN ITEM_TYPE IN('L',
                                                        'K') THEN NULL
                                      WHEN ITEM_TYPE IN('O',
                                                        'E') THEN gcm_get_sampleid_for_test_ord(TST_ID)
                                      WHEN ITEM_TYPE IN('F',
                                                        'T',
                                                        'P',
                                                        'S') THEN TO_CHAR(gcm_get_sampleid_for_interp(GP_REQI_RECID))
                                      ELSE gcm_get_sampleid_for_order(ORDNUM)
                                  END) AS SAMPLEID,
                                 GP_ORD_EXTNUM AS SOFTLABORDNUM
   FROM
     (SELECT VCORE.*
      FROM
        (SELECT GP_ORD_ORDNUM AS ORDNUM,
                (CASE
                     WHEN GP_OTST_CTYPE = 'C'
                          AND GP_OTST_TYPE = 'A'
                          AND GS_TST_ANTP IN ('G',
                                              'H')
                          AND GS_TST_RESKEYPAD = 'Y' THEN 'Y'
                     ELSE 'N'
                 END) AS ANALYSIS_KEYPAD,
                GP_ORD_SECEXTNUM,
                'N' AS SIGNOUT,
                GP_OTST_STATUS,
                NULL AS GP_REQI_PEND,
                GP_ORD_VISID,
                GP_ORD_CTYPE||'#'||GP_ORD_ORDNUM AS GP_ORD_ORDNUM,
                GP_ORD_ORDNUM AS ORIGINAL_LABNO,
                GP_ORD_RECID,
                GP_ORD_GRP,
                GP_ORD_PRIOR AS ORD_PRIOR,
                GP_ORD_REGDT,
                GP_OTST_RECID AS TST_ID,
                GP_ORD_ISIFLOW,
                ((CASE
                      WHEN (GP_OTST_RPTID IS NOT NULL) THEN 'Final Test-Specific Report for '
                      WHEN (GS_TST_CTYPE IN ('C',
                                             'M',
                                             'B',
                                             'H',
                                             'O',
                                             'L')) THEN 'Test '
                      WHEN (GS_TST_CTYPE IN ('P',
                                             'F')) THEN 'Panel '
                  END) || GP_OTST_CODE) AS ITEM,
                GS_TST_CODEBASE AS GS_TST_CODE,
                NVL(GP_OTST_ALIAS, GP_ORD_ALIASES) AS ALIASNUM,
                (CASE
                     WHEN (GS_TST_CTYPE = 'C') THEN ctg_casestatus_utils.GET_PENDING_ACTIVITY(GP_OTST_RECID)
                     WHEN (GS_TST_CTYPE = 'F') THEN (CASE
                                                         WHEN (GP_OTST_NACT IS NOT NULL
                                                               AND GP_OTST_NACT != '!TINT') THEN
                                                                (SELECT GS_ACT_NAME
                                                                 FROM GS_ACTIV
                                                                 WHERE GS_ACT_CODE = GP_OTST_NACT)
                                                         WHEN (EXISTS
                                                                 (SELECT *
                                                                  FROM GP_FLW_PANELTUBE
                                                                  WHERE GP_F_PTU_PANELID = GP_OTST_RECID
                                                                    AND GP_F_PTU_NACT IN ('!PARE') )) THEN
                                                                (SELECT GS_ACT_NAME
                                                                 FROM GS_ACTIV
                                                                 WHERE GS_ACT_CODE = '!TREZ')
                                                         WHEN (EXISTS
                                                                 (SELECT *
                                                                  FROM GP_FLW_PANELTUBE
                                                                  WHERE GP_F_PTU_PANELID = GP_OTST_RECID
                                                                    AND GP_F_PTU_NACT IN ('!PARV') )) THEN
                                                                (SELECT GS_ACT_NAME
                                                                 FROM GS_ACTIV
                                                                 WHERE GS_ACT_CODE = '!TREV')
                                                         ELSE 'Test Review'
                                                     END)
                     WHEN (GS_TST_CTYPE IN ('P',
                                            'M',
                                            'B')) THEN (CASE
                                                            WHEN GP_OTST_PEND = 'D' THEN GS_ACT_NAME
                                                            ELSE 'Test Review'
                                                        END)
                     WHEN GS_TST_CTYPE IN ('H') THEN GS_ACT_NAME
                 END) AS ACTIVITY,
                GP_OTST_RECID AS UNIQUEID,
                0 AS RELATED_UNIQUEID,
                NULL AS GP_REQI_REPNUM,
                '' AS GP_PLR_OTHERS,
                '' AS GP_PLR_OWNTP,
                (CASE
                     WHEN GP_OTST_CTYPE = 'F' THEN FLW_GET_PANELTUBES_TASKLIST(NULL, NULL, NULL, GP_OTST_RECID)
                     ELSE NULL
                 END) AS PANEL_TUBE_TASKLIST_NUMBER,
                0 AS GP_SPE_GEST,
                (CASE
                     WHEN (GS_TST_CTYPE = 'C') THEN (GP_OTST_SLDDONESCR || '/' || GP_OTST_SLDPEND)
                     ELSE NULL
                 END) AS NUMSLIDE,
                GP_OTST_ASSIGN AS ASSIGN,
                'O' AS GP_ASH_ITEMTYPE,
                GP_OTST_ASSIGNDATE AS ASHDATE,
                'E' AS ITEM_TYPE,
                GP_ORD_PATHOLOGIST,
                (CASE
                     WHEN (GP_OTST_AUTORELEASE = 'Y'
                           AND GP_OTST_CTYPE='F') THEN (CASE
                                                            WHEN (GS_TST_TECHONLYTATUNIT = 'd') THEN GS_TST_TECHONLYTAT * 24 * 60
                                                            ELSE GS_TST_TECHONLYTAT * 60
                                                        END)
                     ELSE (CASE
                               WHEN (GS_TST_TATUNIT = 'd') THEN GS_TST_TAT * 24 * 60
                               ELSE GS_TST_TAT * 60
                           END)
                 END) AS GS_TST_TAT,
                (CASE
                     WHEN (GP_OTST_AUTORELEASE = 'Y'
                           AND GP_OTST_CTYPE='F') THEN (CASE
                                                            WHEN (GS_TST_TECHONLYTATUNIT = 'd') THEN (CASE
                                                                                                          WHEN (GS_TST_TAT IS NULL
                                                                                                                OR GS_TST_TAT = 0) THEN NULL
                                                                                                          ELSE ((GS_TST_TATHIGH/GS_TST_TAT) * GS_TST_TECHONLYTAT * 24 * 60)
                                                                                                      END)
                                                            ELSE (CASE
                                                                      WHEN (GS_TST_TAT IS NULL
                                                                            OR GS_TST_TAT = 0) THEN NULL
                                                                      ELSE ((GS_TST_TATHIGH/GS_TST_TAT) * GS_TST_TECHONLYTAT * 60)
                                                                  END)
                                                        END)
                     ELSE (CASE
                               WHEN (GS_TST_TATUNIT = 'd') THEN GS_TST_TATHIGH * 24 * 60
                               ELSE GS_TST_TATHIGH * 60
                           END)
                 END) AS GS_TST_TATHIGH,
                GS_TST_CTYPE AS SYSTEM_TYPE,
                GP_ORD_DEPARTMENT AS ORDER_DEPARTMENT,
                GP_OTST_DEPARTMENT AS PERF_DEPARTMENT,
                GP_ORD_DEPARTMENT AS ORD_DEP_RECID,
                GP_OTST_DEPARTMENT AS PRF_DEP_RECID,
                REPLACE(REPLACE(REPLACE(GP_ORD_ORDEREDTESTS, '|', ','), '/,', '|'), '//', '/') AS ORDERED_TESTS,
                GP_ORD_FIRSTFORPAT AS NEW_PATIENT,
                NULL AS GP_TSTWKL_RECID,
                (CASE
                     WHEN EXISTS
                            (SELECT GP_NOTE_RECID
                             FROM GP_NOTE
                             WHERE GP_NOTE_ORDNUM = GP_ORD_ORDNUM
                               AND GP_NOTE_ACT = 'Y') THEN 'Y'
                     ELSE 'N'
                 END) AS ACTIVE_NOTE,
                NULL AS ORDER_SYSTEM_TYPE,
                gs_dep_site AS SITE,
                (CASE
                     WHEN (GP_OTST_PEND = 'D'
                           AND GS_TST_CTYPE IN ('M',
                                                'H')
                           AND GS_ACT_MD_DASHBORDVISIBLE = 'Y') THEN (CASE
                                                                          WHEN GS_ACT_MD_ENTRYFOROPENBT = 'L' THEN 'Tasklist'
                                                                          WHEN GS_ACT_MD_ENTRYFOROPENBT = 'N' THEN 'New Tasklist'
                                                                          WHEN GS_ACT_MD_ENTRYFOROPENBT = 'T' THEN 'TST_REV'
                                                                          ELSE ''
                                                                      END)
                     ELSE ''
                 END) AS ENTRY,
                '' AS STATUS,
                '' AS PREV_ITEM,
                GP_OTST_CODE,
                GP_OTST_PRIORITY,
                Nvl(TO_CHAR(CAST(GP_OTST_REGDT AS TIMESTAMP WITH TIME ZONE), 'mm/dd/YYYY HH24:MI TZH:TZM'), ' ') AS GP_OTST_REGDT,
                GP_OTST_ISPRELREP,

           (SELECT GP_OTR_KTYPE
            FROM GP_OTESTRESULT
            WHERE GP_OTR_TESTID = GP_OTST_RECID
              AND GP_OTR_REVREPORTID IS NULL) AS KTYPE,
                GP_ORD_ABN,
                GP_ORD_GESTAGE,
                GP_OTST_INDICATIONS AS IND_TST,
                GP_ORD_LMOD,
                GP_OTST_INDNAMES AS INDICATIONNAMES,
                GP_OTST_SPECTYPES AS SPEC_TYPES,
                'TEST' AS ETYPE,
                (CASE
                     WHEN (GP_OTST_PEND = 'R'
                           AND GP_OTR_EMP = NVL(GP_OTST_ASSIGN, '-1'))
                          OR (GS_TST_CTYPE = 'M'
                              AND EXISTS
                                (SELECT GP_ACT_RECID
                                 FROM GP_ACTION
                                 WHERE GP_ACT_RECID = GP_OTST_LASTACT
                                   AND GP_ACT_EMP = NVL(GP_OTST_ASSIGN, '-1') )) THEN 'Y'
                     ELSE 'N'
                 END) AS USER_LASTACT,
                'N' AS ISTASKLISTS,
                -1 AS PARENT_ID,
                get_all_spec_coldt_for_test(GP_OTST_RECID) AS GP_SPE_COLDT,
                GP_ORD_EXTNUM,
                NULL AS GP_REQI_RECID,
                NULL AS GP_OTST_RECID,
                NULL AS GP_REQI_DEPTYPE,
                NULL AS GP_REQI_TESTID,
                NULL AS GP_REQI_INTTYPE,
                (CASE
                     WHEN GP_REQI_INTTYPE = 'T' THEN (CASE
                                                          WHEN NOT EXISTS
                                                                 (SELECT GP_INT_RECID
                                                                  FROM GP_INTERP
                                                                  WHERE GP_INT_TESTID = GP_OTST_RECID
                                                                    AND GP_INT_REVREPORTID IS NULL
                                                                    AND GP_INT_TYPE = 'T') THEN GP_OTR_ABN
                                                          ELSE NVL(
                                                                     (SELECT GP_INT_ABN
                                                                      FROM GP_INTERP
                                                                      WHERE GP_INT_TESTID = GP_OTST_RECID
                                                                        AND GP_INT_REVREPORTID IS NULL
                                                                        AND GP_INT_TYPE = 'T'), GP_OTR_ABN)
                                                      END)
                     ELSE (CASE
                               WHEN
                                      (SELECT COUNT(DISTINCT(otest.GP_OTR_ABN))
                                       FROM GP_OTEST test,
                                            GP_OTESTRESULT otest
                                       WHERE test.GP_OTST_REQIID = GP_REQI_RECID
                                         AND otest.GP_OTR_REVREPORTID IS NULL
                                         AND otest.GP_OTR_TESTID = test.GP_OTST_RECID) = 1 THEN GP_OTR_ABN
                               ELSE NULL
                           END)
                 END) AS GP_INT_ABN,
                NULL AS GP_INT_DGNCAT,
                GET_LAST_RESULT_TASKLIST(GP_OTST_RECID, 'N') AS TASKLIST_NUM,
                (CASE
                     WHEN EXISTS
                            (SELECT O.GP_OTST_RECID
                             FROM GP_OTEST O,
                                  GS_TEST T
                             WHERE O.GP_OTST_PANELID IN
                                 (SELECT GP_OTST_RECID
                                  FROM GP_OTEST S
                                  WHERE GP_ORD_ORDNUM = S.GP_OTST_ORDNUM )
                               AND O.GP_OTST_CODE = T.GS_TST_CODE
                               AND T.GS_TST_TYPE = 'B') THEN 'Y'
                     ELSE 'N'
                 END) AS PROBES,
                GCM_GET_GPFLWRUN_PATH(GP_OTST_RECID) AS FLWRUN_PATH,
                (CASE
                     WHEN EXISTS
                            (SELECT GS_TKL_POSFLG
                             FROM GS_TASKLIST,
                                  GP_TESTWKL
                             WHERE GP_TSTWKL_RECID = GP_OTST_TASKLISTID
                               AND GS_TKL_RECID = GP_TSTWKL_TEMPLATEID
                               AND GS_TKL_POSFLG = 'Y') THEN
                            (SELECT GP_TWL_POSTST
                             FROM GP_TESTWKLLINK
                             WHERE GP_TWL_OWNID = GP_OTST_RECID
                               AND GP_TWL_WKLID = GP_OTST_TASKLISTID
                               AND GP_TWL_ISTSTDETACHED = 'N'
                               AND GP_TWL_OWNTP = 'T')
                     ELSE NULL
                 END) AS TKL_POS,
                NULL AS GP_PLR_PRQACODE,
                NULL AS QUALITY_DESC,
                get_pending_stains(GP_ORD_ORDNUM) AS PENDINGSTAINS
         FROM GP_OTEST,
              GS_TEST,
              GP_ORDER,
              GS_DEPARTMENT,
              GP_OTESTRESULT,
              GP_REQINTERP,
              GS_ACTIV
         WHERE GP_ORD_ORDNUM = GP_OTST_ORDNUM
           AND GP_REQI_RECID(+) = GP_OTST_REQIID
           AND GP_OTR_TESTID(+) = GP_OTST_RECID
           AND (CASE
                    WHEN GP_OTR_REVREPORTID IS NULL THEN 1
                    ELSE 0
                END) = 1
           AND GP_OTST_CODEVER = GS_TST_CODEVER
           AND GP_ORD_OLD = 'N'
           AND GP_ORD_STS = 'B'
           AND (CASE
                    WHEN GP_OTST_STATUS IN ('R',
                                            'F') THEN 0
                    ELSE 1
                END) = 1
           AND GP_OTST_DEPARTMENT = GS_DEP_RECID(+)
           AND GP_ORD_DISCONT = 'N'
           AND GS_TST_TYPE IN('A',
                              'P',
                              'Y')
           AND GS_ACT_CODE(+) = GP_OTST_NACT
           AND (CASE
                    WHEN GP_OTST_PEND IN ('A',
                                          'R') THEN 1
                    WHEN GP_OTST_PEND = 'D'
                         AND GS_ACT_MD_DASHBORDVISIBLE = 'Y' THEN 1
                    ELSE 0
                END) = 1
           AND GP_OTST_ASSIGN = 'GMOLR'
           AND ROWNUM <= 1002
         UNION ALL SELECT GP_ORD_ORDNUM AS ORDNUM,
                          'N' AS ANALYSIS_KEYPAD,
                          GP_ORD_SECEXTNUM,
                          'N' AS SIGNOUT,
                          NULL AS GP_OTST_STATUS,
                          NULL AS GP_REQI_PEND,
                          GP_ORD_VISID,
                          GP_ORD_CTYPE||'#'||GP_ORD_ORDNUM AS GP_ORD_ORDNUM,
                          GP_ORD_ORDNUM AS ORIGINAL_LABNO,
                          GP_ORD_RECID,
                          GP_ORD_GRP,
                          GP_ORD_PRIOR AS ORD_PRIOR,
                          GP_ORD_REGDT,
                          NULL AS TST_ID,
                          GP_ORD_ISIFLOW,
                          'Order' AS ITEM,
                          NULL AS GS_TST_CODE,
                          GP_ORD_ALIASES AS ALIASNUM,
                          GS_ACT_NAME AS ACTIVITY,
                          act_owner_id AS UNIQUEID,
                          0 AS RELATED_UNIQUEID,
                          NULL AS GP_REQI_REPNUM,
                          NULL AS GP_PLR_OTHERS,
                          NULL AS GP_PLR_OWNTP,
                          NULL AS PANEL_TUBE_TASKLIST_NUMBER,
                          NULL AS GP_SPE_GEST,
                          NULL AS NUMSLIDE,
                          EMPL AS ASSIGN,
                          NULL AS GP_ASH_ITEMTYPE,
                          NULL AS ASHDATE,
                          'N' AS ITEM_TYPE,
                          GP_ORD_PATHOLOGIST,
                          NULL AS GS_TST_TAT,
                          NULL AS GS_TST_TATHIGH,
                          GS_ACT_SYSTEM AS SYSTEM_TYPE,
                          GP_ORD_DEPARTMENT AS ORDER_DEPARTMENT,
                          NULL AS PERF_DEPARTMENT,
                          GP_ORD_DEPARTMENT AS ORD_DEP_RECID,
                          NULL AS PRF_DEP_RECID,
                          REPLACE(REPLACE(REPLACE(GP_ORD_ORDEREDTESTS, '|', ','), '/,', '|'), '//', '/') AS ORDERED_TESTS,
                          GP_ORD_FIRSTFORPAT AS NEW_PATIENT,
                          NULL AS GP_TSTWKL_RECID,
                          (CASE
                               WHEN EXISTS
                                      (SELECT GP_NOTE_RECID
                                       FROM GP_NOTE
                                       WHERE GP_NOTE_ORDNUM = GP_ORD_ORDNUM
                                         AND GP_NOTE_ACT = 'Y') THEN 'Y'
                               ELSE 'N'
                           END) AS ACTIVE_NOTE,
                          NULL AS ORDER_SYSTEM_TYPE,
                          GS_PLC_site AS SITE,
                          OAENTRY AS ENTRY,
                          '' AS STATUS,
                          '' AS PREV_ITEM,
                          NULL AS GP_OTST_CODE,
                          NULL AS GP_OTST_PRIORITY,
                          NULL AS GP_OTST_REGDT,
                          NULL AS GP_OTST_ISPRELREP,
                          NULL AS KTYPE,
                          GP_ORD_ABN,
                          GP_ORD_GESTAGE,
                          GP_ORD_INDICATIONS AS IND_TST,
                          GP_ORD_LMOD,
                          GP_ORD_INDNAMES AS INDICATIONNAMES,
                          GP_ORD_ORDEREDSPEC AS SPEC_TYPES,
                          'ORDER ACTION' AS ETYPE,
                          NULL AS USER_LASTACT,
                          'N' AS ISTASKLISTS,
                          -1 AS PARENT_ID,
                          get_all_spec_coldt_for_order(GP_ORD_ORDNUM) AS GP_SPE_COLDT,
                          GP_ORD_EXTNUM,
                          NULL AS GP_REQI_RECID,
                          NULL AS GP_OTST_RECID,
                          NULL AS GP_REQI_DEPTYPE,
                          NULL AS GP_REQI_TESTID,
                          NULL AS GP_REQI_INTTYPE,
                          NULL AS ABN,
                          NULL AS GP_INT_DGNCAT,
                          GET_LAST_RESULT_TASKLIST_ORD(GP_ORD_ORDNUM, 'N') AS TASKLIST_NUM,
                          NULL AS PROBES,
                          NULL AS FLWRUN_PATH,
                          NULL AS TKL_POS,
                          NULL AS GP_PLR_PRQACODE,
                          NULL AS QUALITY_DESC,
                          get_pending_stains(GP_ORD_ORDNUM) AS PENDINGSTAINS
         FROM
           (SELECT gp_oa_recid AS act_owner_id,
                   gp_oa_ordid AS ordid,
                   gp_oa_actcode AS actcode,
                   gp_oa_empl AS empl,
                   gp_oa_entry AS oaentry
            FROM gp_ordact
            WHERE gp_oa_completed != 'Y'
            UNION SELECT gp_ord_recid AS act_owner_id,
                         gp_ord_recid AS ordid,
                         gp_ord_nact AS actcode,
                         gp_ord_nactemp AS empl,
                         gp_ord_nactentry AS oaentry
            FROM gp_order
            WHERE gp_ord_nact IS NOT NULL ) ORDACTS,
              GP_ORDER,
              GS_PLACE,
              GS_ACTIV
         WHERE GP_ORD_RECID = ORDID
           AND ACTCODE = GS_ACT_CODE
           AND GP_ORD_DEPARTMENT = GS_PLC_RECID
           AND (GP_ORD_SIGNOUTDT IS NULL
                OR GP_ORD_INACT = 'R')
           AND nvl(GP_ORD_INACT, 'NULL') != 'D'
           AND EMPL = 'GMOLR'
           AND ROWNUM <= 1002
         UNION ALL SELECT GP_ORD_ORDNUM AS ORDNUM,
                          (CASE
                               WHEN (GP_REQI_INTTYPE = 'T'
                                     OR (GP_REQI_INTTYPE = 'P'
                                         AND GP_REQI_TESTID IS NOT NULL)) THEN (CASE
                                                                                    WHEN GP_OTST_CTYPE = 'C'
                                                                                         AND GP_OTST_TYPE = 'A'
                                                                                         AND GS_TST_ANTP IN ('G',
                                                                                                             'H')
                                                                                         AND GS_TST_RESKEYPAD = 'Y' THEN 'Y'
                                                                                    ELSE 'N'
                                                                                END)
                               ELSE 'N'
                           END) AS ANALYSIS_KEYPAD,
                          GP_ORD_SECEXTNUM,
                          (CASE
                               WHEN GP_REQI_PEND = 'S' THEN 'Y'
                               ELSE 'N'
                           END) AS SIGNOUT,
                          CASE
                              WHEN GP_REQI_PEND = 'S' THEN 'W'
                              WHEN GP_REQI_INTTYPE = 'T' THEN GP_OTST_STATUS
                              WHEN GP_REQI_INTTYPE IN ('F',
                                                       'P',
                                                       'S') THEN CASE
                                                                     WHEN GP_REQI_INTSTATUS = 'N' THEN 'J'
                                                                     WHEN GP_REQI_INTSTATUS = 'I' THEN 'L'
                                                                     WHEN (GP_REQI_INTSTATUS = 'C'
                                                                           AND GP_REQI_INTREVSTATUS != 'C'
                                                                           AND NVL(
                                                                                     (SELECT GP_INT_RNEEDED
                                                                                      FROM GP_INTERP
                                                                                      WHERE GP_INT_REQID = GP_REQI_RECID
                                                                                        AND GP_INT_REVREPORTID IS NULL),'N') = 'Y') THEN 'K'
                                                                     WHEN (GP_REQI_INTSTATUS = 'C'
                                                                           AND GP_REQI_INTREVSTATUS = 'C'
                                                                           AND NVL(
                                                                                     (SELECT GP_INT_RNEEDED
                                                                                      FROM GP_INTERP
                                                                                      WHERE GP_INT_REQID = GP_REQI_RECID
                                                                                        AND GP_INT_REVREPORTID IS NULL),'N') = 'Y'
                                                                           AND GP_REQI_INTSREVSTATUS != 'C'
                                                                           AND NVL(
                                                                                     (SELECT GP_INT_SRNEEDED
                                                                                      FROM GP_INTERP
                                                                                      WHERE GP_INT_REQID = GP_REQI_RECID
                                                                                        AND GP_INT_REVREPORTID IS NULL),'N') = 'Y') THEN 'K'
                                                                     WHEN ((GP_REQI_INTSTATUS = 'C'
                                                                            AND NVL(
                                                                                      (SELECT GP_INT_RNEEDED
                                                                                       FROM GP_INTERP
                                                                                       WHERE GP_INT_REQID = GP_REQI_RECID
                                                                                         AND GP_INT_REVREPORTID IS NULL),'N') = 'N')
                                                                           OR GP_REQI_INTREVSTATUS = 'C') THEN 'W'
                                                                     ELSE GP_OTST_STATUS
                                                                 END
                              ELSE GP_OTST_STATUS
                          END AS GP_OTST_STATUS,
                          GP_REQI_PEND,
                          GP_ORD_VISID,
                          GP_ORD_CTYPE||'#'||GP_ORD_ORDNUM AS GP_ORD_ORDNUM,
                          GP_ORD_ORDNUM AS ORIGINAL_LABNO,
                          GP_ORD_RECID,
                          GP_ORD_GRP,
                          GP_ORD_PRIOR AS ORD_PRIOR,
                          GP_ORD_REGDT,
                          (CASE
                               WHEN (GP_REQI_INTTYPE = 'T'
                                     OR (GP_REQI_INTTYPE = 'P'
                                         AND GP_REQI_TESTID IS NOT NULL)) THEN GP_OTST_RECID
                               ELSE ROUND((SYSDATE - GP_ORD_REGDT) * 24 * 60, 0)
                           END) AS TST_ID,
                          GP_ORD_ISIFLOW,
                          (CASE
                               WHEN (GP_REQI_INTTYPE = 'T'
                                     AND GP_REQI_PEND = 'N') THEN 'Test ' || GP_OTST_CODE
                               WHEN (GP_REQI_INTTYPE = 'T') THEN 'Final Test-Specific Report for ' || GP_OTST_CODE
                               WHEN (GP_REQI_INTTYPE = 'F') THEN 'Final Report' || ' for '||
                                      (SELECT GS_DEPT_CODE
                                       FROM GS_DEPARTMENTTYPE
                                       WHERE GS_DEPT_RECID = GP_REQI_DEPTYPE)
                               WHEN (GP_REQI_INTTYPE = 'P'
                                     AND GP_REQI_TESTID IS NOT NULL) THEN 'Preliminary Test-Specific Report for ' || GP_OTST_CODE
                               WHEN (GP_REQI_INTTYPE = 'P'
                                     AND GP_REQI_TESTID IS NULL) THEN 'Preliminary Report' || ' for '||
                                      (SELECT GS_DEPT_CODE
                                       FROM GS_DEPARTMENTTYPE
                                       WHERE GS_DEPT_RECID = GP_REQI_DEPTYPE)
                               WHEN (GP_REQI_INTTYPE = 'S'
                                     AND GP_REQI_TESTID IS NOT NULL) THEN 'Supplemental ' || 'Test-Specific Report for ' || GP_OTST_CODE
                               WHEN (GP_REQI_INTTYPE = 'S'
                                     AND GP_REQI_TESTID IS NULL) THEN 'Supplemental ' || 'Report for ' ||
                                      (SELECT GS_DEPT_CODE
                                       FROM GS_DEPARTMENTTYPE
                                       WHERE GS_DEPT_RECID = GP_REQI_DEPTYPE)
                               ELSE ' '
                           END) AS ITEM,
                          GS_TST_CODEBASE AS GS_TST_CODE,
                          NVL(GP_REQI_ALIAS, GP_ORD_ALIASES) AS ALIASNUM,
                          (CASE WHEN(GP_REQI_PEND = 'I')THEN 'Interpretation Results' WHEN(GP_REQI_PEND = 'R')THEN 'Interpretation Review' WHEN(GP_REQI_PEND = 'S')THEN 'Sign Out'
                           END) AS ACTIVITY,
                          GP_REQI_RECID AS UNIQUEID,
                          GP_REQI_TESTID AS RELATED_UNIQUEID,
                          GP_REQI_REPNUM,
                          '' AS GP_PLR_OTHERS,
                          '' AS GP_PLR_OWNTP,
                          (CASE
                               WHEN GP_REQI_CTYPE = 'F' THEN FLW_GET_PANELTUBES_TASKLIST(NULL, GP_REQI_RECID, GP_REQI_INTTYPE, NULL)
                               ELSE NULL
                           END) AS PANEL_TUBE_TASKLIST_NUMBER,
                          0 AS GP_SPE_GEST,
                          (CASE
                               WHEN (GS_TST_CTYPE = 'C') THEN (GP_OTST_SLDDONESCR || '/' || GP_OTST_SLDPEND)
                               ELSE NULL
                           END) AS NUMSLIDE,
                          GP_REQI_ASSIGN AS ASSIGN,
                          '' AS GP_ASH_ITEMTYPE,
                          GP_REQI_ASSIGNDATE AS ASHDATE,
                          GP_REQI_INTTYPE AS ITEM_TYPE,
                          GP_ORD_PATHOLOGIST,
                          (CASE
                               WHEN (GS_TST_TAT IS NULL
                                     AND GP_REQI_INTTYPE <> 'T') THEN GCM_GET_MAX_TAT(GP_ORD_ORDNUM)
                               ELSE (CASE
                                         WHEN (GP_OTST_AUTORELEASE = 'Y'
                                               AND GP_OTST_CTYPE='F') THEN (CASE
                                                                                WHEN (GS_TST_TECHONLYTATUNIT = 'd') THEN GS_TST_TECHONLYTAT * 24 * 60
                                                                                ELSE GS_TST_TECHONLYTAT * 60
                                                                            END)
                                         ELSE (CASE
                                                   WHEN (GS_TST_TATUNIT = 'd') THEN GS_TST_TAT * 24 * 60
                                                   ELSE GS_TST_TAT * 60
                                               END)
                                     END)
                           END) AS GS_TST_TAT,
                          (CASE
                               WHEN (GP_OTST_AUTORELEASE = 'Y'
                                     AND GP_OTST_CTYPE='F') THEN (CASE
                                                                      WHEN (GS_TST_TECHONLYTATUNIT = 'd') THEN (CASE
                                                                                                                    WHEN (GS_TST_TAT IS NULL
                                                                                                                          OR GS_TST_TAT = 0) THEN NULL
                                                                                                                    ELSE ((GS_TST_TATHIGH/GS_TST_TAT) * GS_TST_TECHONLYTAT * 24 * 60)
                                                                                                                END)
                                                                      ELSE (CASE
                                                                                WHEN (GS_TST_TAT IS NULL
                                                                                      OR GS_TST_TAT = 0) THEN NULL
                                                                                ELSE ((GS_TST_TATHIGH/GS_TST_TAT) * GS_TST_TECHONLYTAT * 60)
                                                                            END)
                                                                  END)
                               ELSE (CASE
                                         WHEN (GS_TST_TATUNIT = 'd') THEN GS_TST_TATHIGH * 24 * 60
                                         ELSE GS_TST_TATHIGH * 60
                                     END)
                           END) AS GS_TST_TATHIGH,
                          GP_REQI_CTYPE AS SYSTEM_TYPE,
                          GP_ORD_DEPARTMENT AS ORDER_DEPARTMENT,
                          GP_REQI_DEPARTMENT AS PERF_DEPARTMENT,
                          GP_ORD_DEPARTMENT AS ORD_DEP_RECID,
                          GP_REQI_DEPARTMENT AS PRF_DEP_RECID,
                          REPLACE(REPLACE(REPLACE(GP_ORD_ORDEREDTESTS, '|', ','), '/,', '|'), '//', '/') AS ORDERED_TESTS,
                          GP_ORD_FIRSTFORPAT AS NEW_PATIENT,
                          NULL AS GP_TSTWKL_RECID,
                          (CASE
                               WHEN EXISTS
                                      (SELECT GP_NOTE_RECID
                                       FROM GP_NOTE
                                       WHERE GP_NOTE_ORDNUM = GP_ORD_ORDNUM
                                         AND GP_NOTE_ACT = 'Y') THEN 'Y'
                               ELSE 'N'
                           END) AS ACTIVE_NOTE,
                          NULL AS ORDER_SYSTEM_TYPE,

           (SELECT GS_DEP_SITE
            FROM GS_DEPARTMENT
            WHERE GS_DEP_RECID = GP_REQI_DEPARTMENT) AS SITE,
                          '' AS ENTRY,
                          '' AS STATUS,
                          '' AS PREV_ITEM,
                          (CASE
                               WHEN GP_OTST_CODE IS NOT NULL THEN GP_OTST_CODE
                               ELSE
                                      (SELECT STRING_COMMA_AGGR(GP_OTST_CODE)
                                       FROM GP_REQINTERP,
                                            GP_OTEST
                                       WHERE GP_REQI_ORDNUM = GP_ORD_ORDNUM
                                         AND NVL2(GP_REQI_ASSIGN, GP_REQI_ASSIGN, NVL2(GP_REQI_ASSINGNINT, GP_REQI_ASSINGNINT, NVL2(GP_REQI_ASSINGNINTREV, GP_REQI_ASSINGNINTREV, NVL2(GP_REQI_ASSINGNSIG, GP_REQI_ASSINGNSIG, GP_ORD_PATHOLOGIST)))) = 'GMOLR'
                                         AND GP_REQI_INTTYPE IN ('F',
                                                                 'P',
                                                                 'S')
                                         AND GP_REQI_RECID(+) = GP_OTST_REQIID
                                         AND GP_OTST_PANELID IS NULL)
                           END) AS GP_OTST_CODE,
                          GP_OTST_PRIORITY,
                          (CASE
                               WHEN GP_REQI_INTTYPE = 'P' THEN
                                      (SELECT RTRIM(EXTRACT(XMLAGG(XMLELEMENT("s", Nvl(TO_CHAR(CAST(t.GP_OTST_REGDT AS TIMESTAMP WITH TIME ZONE), 'mm/dd/YYYY HH24:MI TZH:TZM'), ' ') || ';')
                                                                   ORDER BY t.gp_otst_code), '/s/text()') .getstringval(), ';')
                                       FROM gp_otest t,
                                            gp_reqinterp t1,
                                            gp_reqinterp t2
                                       WHERE t.gp_otst_reqiid = t1.gp_reqi_recid
                                         AND t1.gp_reqi_ordnum = t2.gp_reqi_ordnum
                                         AND t1.gp_reqi_deptype = t2.gp_reqi_deptype
                                         AND nvl(t1.gp_reqi_testid, -1) = nvl(t2.gp_reqi_testid, -1)
                                         AND t1.gp_reqi_inttype IN ('F',
                                                                    'T')
                                         AND t2.gp_reqi_inttype = 'P'
                                         AND t2.gp_reqi_recid = r.gp_reqi_recid)
                               WHEN GP_REQI_INTTYPE = 'F'
                                    OR GP_REQI_INTTYPE = 'T' THEN
                                      (SELECT RTRIM(EXTRACT(XMLAGG(XMLELEMENT("s", Nvl(TO_CHAR(CAST(t.GP_OTST_REGDT AS TIMESTAMP WITH TIME ZONE), 'mm/dd/YYYY HH24:MI TZH:TZM'), ' ') || ';')
                                                                   ORDER BY t.gp_otst_code), '/s/text()').getstringval(), ';')
                                       FROM gp_otest t,
                                            gp_reqinterp r1
                                       WHERE r1.gp_reqi_recid = r.gp_reqi_recid
                                         AND t.gp_otst_reqiid = r1.gp_reqi_recid)
                           END) AS GP_OTST_REGDT,
                          GP_OTST_ISPRELREP,
                          NVL(
                                (SELECT GP_INT_KTYPE
                                 FROM GP_INTERP
                                 WHERE GP_INT_REQID = GP_REQI_RECID
                                   AND GP_INT_REVREPORTID IS NULL),
                                (SELECT GP_OTR_KTYPE
                                 FROM GP_OTESTRESULT
                                 WHERE GP_OTR_TESTID = GP_OTST_RECID
                                   AND GP_OTR_REVREPORTID IS NULL)) AS KTYPE,
                          GP_ORD_ABN,
                          GP_ORD_GESTAGE,
                          (CASE
                               WHEN GP_OTST_CODE IS NOT NULL THEN GP_OTST_INDICATIONS
                               ELSE GP_ORD_INDICATIONS
                           END) AS IND_TST,
                          GP_ORD_LMOD,
                          (CASE
                               WHEN GP_OTST_CODE IS NOT NULL THEN GP_OTST_INDNAMES
                               ELSE GP_ORD_INDNAMES
                           END) AS INDICATIONNAMES,
                          (CASE
                               WHEN GP_OTST_CODE IS NOT NULL THEN GP_OTST_SPECTYPES
                               ELSE GP_ORD_ORDEREDSPEC
                           END) AS SPEC_TYPES,
                          'INTERP' AS ETYPE,
                          (CASE
                               WHEN (GP_REQI_PEND = 'I'
                                     AND GP_OTST_REVNEED = 'Y'
                                     AND GP_OTR_REMP = NVL(GP_REQI_ASSIGN, '-1')) THEN 'Y'
                               WHEN (GP_REQI_PEND = 'I'
                                     AND NVL(GP_OTST_REVNEED, 'N') = 'N'
                                     AND (GS_TST_CTYPE = 'M'
                                          AND EXISTS
                                            (SELECT GP_ACT_RECID
                                             FROM GP_ACTION
                                             WHERE GP_ACT_RECID = GP_OTST_LASTACT
                                               AND GP_ACT_EMP = NVL(GP_REQI_ASSIGN, '-1') ))) THEN 'Y'
                               WHEN (GP_REQI_PEND = 'I'
                                     AND NVL(GP_OTST_REVNEED, 'N') = 'N'
                                     AND GP_OTR_EMP = NVL(GP_REQI_ASSIGN, '-1')) THEN 'Y'
                               WHEN (GP_REQI_PEND = 'R'
                                     AND NVL(GP_INT_SRNEEDED, 'N') = 'N'
                                     AND GP_INT_EMP = NVL(GP_REQI_ASSIGN, '-1')) THEN 'Y'
                               WHEN (GP_REQI_PEND = 'R'
                                     AND GP_INT_SRNEEDED = 'Y'
                                     AND GP_INT_RCOMP = 'Y'
                                     AND GP_INT_REMP = NVL(GP_REQI_ASSIGN, '-1')) THEN 'Y'
                               WHEN (GP_REQI_PEND = 'R'
                                     AND GP_INT_SRNEEDED = 'Y'
                                     AND GP_INT_COMP = 'Y'
                                     AND GP_INT_EMP = NVL(GP_REQI_ASSIGN, '-1')) THEN 'Y'
                               WHEN (GP_REQI_PEND = 'S'
                                     AND NVL(GP_INT_SRNEEDED, 'N') = 'N'
                                     AND GP_INT_RNEEDED = 'Y'
                                     AND GP_INT_REMP = NVL(GP_REQI_ASSIGN, '-1')) THEN 'Y'
                               WHEN (GP_REQI_PEND = 'S'
                                     AND NVL(GP_INT_SRNEEDED, 'N') = 'N'
                                     AND NVL(GP_INT_RNEEDED, 'N') = 'N'
                                     AND GP_INT_EMP = NVL(GP_REQI_ASSIGN, '-1')) THEN 'Y'
                               WHEN (GP_REQI_PEND = 'S'
                                     AND GP_INT_SRNEEDED = 'Y'
                                     AND GP_INT_RNEEDED = 'Y'
                                     AND GP_INT_SRCOMP = 'Y'
                                     AND GP_INT_SREMP = NVL(GP_REQI_ASSIGN, '-1')) THEN 'Y'
                               WHEN (GP_REQI_PEND = 'S'
                                     AND GP_INT_SRNEEDED = 'Y'
                                     AND GP_INT_RNEEDED = 'Y'
                                     AND GP_INT_RCOMP = 'Y'
                                     AND GP_INT_REMP = NVL(GP_REQI_ASSIGN, '-1')) THEN 'Y'
                               WHEN (GP_REQI_PEND = 'S'
                                     AND GP_INT_SRNEEDED = 'Y'
                                     AND GP_INT_RNEEDED = 'Y'
                                     AND GP_INT_COMP = 'Y'
                                     AND GP_INT_EMP = NVL(GP_REQI_ASSIGN, '-1')) THEN 'Y'
                               ELSE 'N'
                           END) AS USER_LASTACT,
                          'N' AS ISTASKLISTS,
                          -1 AS PARENT_ID,
                          get_all_spec_coldt_for_order(GP_ORD_ORDNUM) AS GP_SPE_COLDT,
                          GP_ORD_EXTNUM,
                          GP_REQI_RECID,
                          GP_OTST_RECID,
                          GP_REQI_DEPTYPE,
                          GP_REQI_TESTID,
                          GP_REQI_INTTYPE,
                          (CASE
                               WHEN GP_REQI_INTTYPE = 'T' THEN (CASE
                                                                    WHEN NOT EXISTS
                                                                           (SELECT GP_INT_RECID
                                                                            FROM GP_INTERP
                                                                            WHERE GP_INT_TESTID = GP_OTST_RECID
                                                                              AND GP_INT_REVREPORTID IS NULL
                                                                              AND GP_INT_TYPE = 'T') THEN GP_OTR_ABN
                                                                    ELSE NVL(
                                                                               (SELECT GP_INT_ABN
                                                                                FROM GP_INTERP
                                                                                WHERE GP_INT_TESTID = GP_OTST_RECID
                                                                                  AND GP_INT_REVREPORTID IS NULL
                                                                                  AND GP_INT_TYPE = 'T'), GP_OTR_ABN)
                                                                END)
                               ELSE
                                      (SELECT GP_INT_ABN
                                       FROM GP_INTERP
                                       WHERE GP_REQI_RECID = GP_INT_REQID
                                         AND GP_INT_REVREPORTID IS NULL )
                           END) AS ABN,
                          GP_INT_DGNCAT,
                          GET_LAST_RESULT_TASKLIST_INTER(GP_REQI_RECID, 'N') AS TASKLIST_NUM,
                          NULL AS PROBES,
                          NULL AS FLWRUN_PATH,
                          NULL AS TKL_POS,
                          NULL AS GP_PLR_PRQACODE,
                          NULL AS QUALITY_DESC,
                          get_pending_stains(GP_ORD_ORDNUM) AS PENDINGSTAINS
         FROM GP_ORDER,
              GP_REQINTERP r,
              GP_OTEST,
              GS_TEST,
              GP_OTESTRESULT,
              GP_INTERP
         WHERE GP_REQI_ORDNUM = GP_ORD_ORDNUM
           AND GP_REQI_RECID = GP_INT_REQID(+)
           AND CASE
                   WHEN GP_OTST_STATUS = 'Y'
                        AND GP_OTST_CTYPE = 'H' THEN 0
                   ELSE 1
               END = 1
           AND (CASE
                    WHEN GP_INT_REVREPORTID IS NULL THEN 1
                    ELSE 0
                END) = 1
           AND GP_OTR_TESTID(+) = GP_OTST_RECID
           AND (CASE
                    WHEN GP_OTR_REVREPORTID IS NULL THEN 1
                    ELSE 0
                END) = 1
           AND GP_ORD_OLD = 'N'
           AND (CASE
                    WHEN (GP_OTST_STATUS = 'F'
                          AND GP_REQI_INTTYPE <> 'S') THEN 0
                    ELSE 1
                END) = 1
           AND GP_REQI_TESTID = GP_OTST_RECID(+)
           AND GP_ORD_DISCONT = 'N'
           AND GP_ORD_STS = 'B'
           AND GP_OTST_CODEVER = GS_TST_CODEVER(+)
           AND GP_REQI_REPSTATUS IN ('N',
                                     'R')
           AND GP_ORD_PARENTNUM IS NULL
           AND GP_REQI_ACTIVE = 'Y'
           AND ((GP_REQI_CTYPE NOT IN ('F',
                                       'P')
                 AND GP_REQI_PEND IN ('I',
                                      'R',
                                      'S'))
                OR (GP_REQI_CTYPE IN ('F',
                                      'P')
                    AND GP_REQI_PEND IN ('I',
                                         'R',
                                         'S')))
           AND GP_REQI_ASSIGN = 'GMOLR'
           AND ((GP_REQI_PEND = 'S'
                 AND GP_REQI_NOREP = 'N')
                OR (GP_REQI_PEND NOT IN ('S')))
           AND ROWNUM <= 1002
         UNION ALL SELECT GP_ORD_ORDNUM AS ORDNUM,
                          'N' AS ANALYSIS_KEYPAD,
                          GP_ORD_SECEXTNUM,
                          'N' AS SIGNOUT,
                          NULL AS GP_OTST_STATUS,
                          NULL AS GP_REQI_PEND,
                          GP_ORD_VISID,
                          GP_ORD_CTYPE||'#'||GP_ORD_ORDNUM AS GP_ORD_ORDNUM,
                          GP_ORD_ORDNUM AS ORIGINAL_LABNO,
                          GP_ORD_RECID,
                          GP_ORD_GRP,
                          GP_ORD_PRIOR AS ORD_PRIOR,
                          GP_ORD_REGDT,
                          (CASE
                               WHEN gp_plr_comp = 'N' THEN ROUND((SYSDATE - gp_plr_regdt) * 24 * 60, 0)
                               ELSE ROUND((gp_plr_date - gp_plr_regdt) * 24 * 60, 0)
                           END) AS TST_ID,
                          GP_ORD_ISIFLOW,
                          gcm_casestatus_utils.GCM_GET_PROBLEM_ITEM(GP_PLR_OWNTP, GP_PLR_OTHERS, GP_PLR_OWNID, GP_PLR_ACTIONCODE, GP_PLR_INTERFACE, 'M') AS ITEM,
                          (CASE
                               WHEN (GP_PLR_OWNTP = 'T') THEN GP_PLR_OTHERS
                               ELSE ''
                           END) AS GS_TST_CODE,
                          NULL AS ALIASNUM,
                          (CASE
                               WHEN (GP_PLR_OWNTP = 'P') THEN 'Specimen Problem'
                               WHEN (GP_PLR_OWNTP = 'V') THEN 'Culture Problem'
                               WHEN (GP_PLR_OWNTP = 'U') THEN 'Receiving Spec/Tube Problem'
                               WHEN (GP_PLR_OWNTP IN ('R',
                                                      'X')) THEN 'Test Review Problem'
                               WHEN (GP_PLR_OWNTP = 'A') THEN 'Panel Problem'
                               WHEN (GP_PLR_OWNTP = 'H') THEN 'Panel Slides Problem'
                               WHEN (GP_PLR_OWNTP = 'C') THEN 'Action Reason Problem'
                               WHEN (GP_PLR_OWNTP = 'S') THEN 'Slide Problem'
                               WHEN (GP_PLR_OWNTP = 'T') THEN 'Analysis Review Problem'
                               WHEN (GP_PLR_OWNTP = 'O') THEN 'Interpretation Review Problem'
                               WHEN (GP_PLR_OWNTP IN ('I',
                                                      'E')) THEN 'Interface Problem'
                               WHEN (GP_PLR_OWNTP = 'RE') THEN 'Requisition Problem'
                               WHEN (GP_PLR_OWNTP = 'UR') THEN 'Requisition Spec/Tube Problem'
                               WHEN (GP_PLR_OWNTP = 'D') THEN 'Requisition Spec/Tube Problem'
                               WHEN (GP_PLR_OWNTP = 'CR') THEN 'Call Request Problem'
                               ELSE ' '
                           END) AS ACTIVITY,
                          GP_PLR_RECID AS UNIQUEID,
                          0 AS RELATED_UNIQUEID,
                          NULL AS GP_REQI_REPNUM,
                          GP_PLR_OTHERS,
                          GP_PLR_OWNTP,
                          NULL AS PANEL_TUBE_TASKLIST_NUMBER,
                          0 AS GP_SPE_GEST,
                          NULL AS NUMSLIDE,
                          GS_PLR_USER AS ASSIGN,
                          'P' AS GP_ASH_ITEMTYPE,
                          GP_PLR_ASSIGNDATE AS ASHDATE,
                          'R' AS ITEM_TYPE,
                          GP_ORD_PATHOLOGIST,

           (SELECT GS_QA_TAT * 24 * 60
