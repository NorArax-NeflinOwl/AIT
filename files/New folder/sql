                          NULL AS PANEL_TUBE_TASKLIST_NUMBER,
                          NULL AS GP_SPE_GEST,
                          NULL AS NUMSLIDE,
                          t.ASSIGN,
                          'L' AS GP_ASH_ITEMTYPE,
                          t.ASHDATE,
                          'L' AS ITEM_TYPE,
                          NULL AS GP_ORD_PATHOLOGIST,
                          NULL AS GS_TST_TAT,
                          NULL AS GS_TST_TATHIGH,
                          GET_SYSTEMS_FOR_TASKLIST(t.GP_TSTWKL_RECID, 'Y') AS SYSTEM_TYPE,
                          NULL AS ORDER_DEPARTMENT,
                          NULL AS PERF_DEPARTMENT,
                          NULL AS ORD_DEP_RECID,
                          NULL AS PRF_DEP_RECID,
                          GET_ORDERED_TESTS_FOR_TASKLIST(t.GP_TSTWKL_RECID, 10) AS ORDERED_TESTS,
                          NULL AS NEW_PATIENT,
                          t.GP_TSTWKL_RECID,
                          'N' AS ACTIVE_NOTE,
                          GET_SYSTEMS_FOR_TASKLIST(t.GP_TSTWKL_RECID) AS ORDER_SYSTEM_TYPE,

           (SELECT GS_DEP_SITE
            FROM GS_DEPARTMENT
            WHERE GS_DEP_RECID = GP_TSTWKL_DEPARTMENT) AS SITE,
                          '' AS ENTRY,
                          '' AS STATUS,
                          '' AS PREV_ITEM,
                          NULL AS GP_OTST_CODE,
                          NULL AS GP_OTST_PRIORITY,
                          NULL AS GP_OTST_REGDT,
                          NULL AS GP_OTST_ISPRELREP,
                          NULL AS KTYPE,
                          NULL GP_ORD_ABN,
                               NULL AS GP_ORD_GESTAGE,
                               NULL AS IND_TST,
                               SYSDATE AS GP_ORD_LMOD,
                               NULL AS INDICATIONNAMES,
                               NULL AS SPEC_TYPES,
                               'TASKLIST_RES' AS ETYPE,
                               'N' AS USER_LASTACT,
                               'Y' AS ISTASKLISTS,
                               -1 AS PARENT_ID,
                               NULL AS GP_SPE_COLDT,
                               NULL AS GP_ORD_EXTNUM,
                               NULL AS GP_REQI_RECID,
                               NULL AS GP_OTST_RECID,
                               NULL AS GP_REQI_DEPTYPE,
                               NULL AS GP_REQI_TESTID,
                               NULL AS GP_REQI_INTTYPE,
                               NULL AS ABN,
                               NULL AS GP_INT_DGNCAT,
                               nvl(GP_TSTWKL_NUM, GP_TSTWKL_RECID) || '' AS TASKLIST_NUM,
                               NULL AS PROBES,
                               NULL AS FLWRUN_PATH,
                               NULL AS TKL_POS,
                               NULL AS GP_PLR_PRQACODE,
                               NULL AS QUALITY_DESC,
                               NULL AS PENDINGSTAINS
         FROM
           (SELECT GP_TSTWKL_BUILTDT AS GP_ORD_REGDT,
                   GP_TSTWKL_ASSIGNEDTOUSER AS ASSIGN,
                   (CASE
                        WHEN GP_TSTWKL_ASSIGNDATE IS NULL THEN GP_TSTWKL_BUILTDT
                        ELSE GP_TSTWKL_ASSIGNDATE
                    END) AS ASHDATE,
                   GP_TSTWKL_RECID,
                   GP_TSTWKL_DEPARTMENT,
                   GS_TKL_CODE,
                   GP_TSTWKL_NUM
            FROM GP_TESTWKL,
                 GS_TASKLIST
            WHERE EXISTS
                (SELECT 1
                 FROM GP_OTEST ORDERED_TEST,
                      GP_TESTWKLLINK
                 WHERE GP_OTST_RECID = GP_TWL_OWNID
                   AND GP_TWL_OWNTP = 'T'
                   AND GP_TSTWKL_RECID = GP_TWL_WKLID
                   AND GP_TWL_ISTSTDETACHED = 'N'
                   AND (CASE
                            WHEN GP_OTST_STATUS = 'H' THEN 0
                            ELSE 1
                        END) = 1
                   AND CASE GP_TSTWKL_COMPLETED
                           WHEN 'Y' THEN 0
                           ELSE 1
                       END = 1
                   AND GP_OTST_PEND IN ('N',
                                        'A',
                                        'R',
                                        'D') )
              AND GP_TSTWKL_ASSIGNEDTOUSER = 'GMOLR'
              AND GP_TSTWKL_TEMPLATEID = GS_TKL_RECID
              AND ROWNUM <= 1002 )t) VCORE
      WHERE ROWNUM <= 1002 )view_records,
        GP_VISIT,
        GP_PATIENT
   WHERE ROWNUM <= 1002
     AND GP_ORD_VISID = GP_VIS_RECID(+)
     AND GP_VIS_PATID = GP_PAT_RECID(+) )v
WHERE ROW_NUM > 0